          width: 20px;\r\n          height: 20px;\r\n          background: #f8f9fa;\r\n          transform: rotate(45deg);\r\n        }\r\n      }\r\n      \r\n      &:nth-child(odd) .timeline-content {\r\n        left: 0;\r\n        \r\n        &::before {\r\n          right: -10px;\r\n        }\r\n      }\r\n      \r\n      &:nth-child(even) .timeline-content {\r\n        left: calc(50% + 30px);\r\n        \r\n        &::before {\r\n          left: -10px;\r\n        }\r\n        \r\n        @media (max-width: 768px) {\r\n          left: 0;\r\n          \r\n          &::before {\r\n            left: -10px;\r\n          }\r\n        }\r\n      }\r\n    }\r\n  }\r\n  \r\n  .timeline-date {\r\n    color: #4CAF50;\r\n    font-weight: 600;\r\n    margin-bottom: 10px;\r\n  }\r\n  \r\n  h3 {\r\n    font-size: 1.3rem;\r\n    margin-bottom: 5px;\r\n    color: #333;\r\n  }\r\n  \r\n  h4 {\r\n    color: #666;\r\n    margin-bottom: 15px;\r\n    font-weight: 500;\r\n  }\r\n  \r\n  p {\r\n    color: #666;\r\n    line-height: 1.6;\r\n    margin-bottom: 15px;\r\n  }\r\n  \r\n  .timeline-skills {\r\n    display: flex;\r\n    flex-wrap: wrap;\r\n    gap: 8px;\r\n    \r\n    span {\r\n      background: white;\r\n      padding: 4px 12px;\r\n      border-radius: 15px;\r\n      font-size: 0.8rem;\r\n      color: #4CAF50;\r\n    }\r\n  }\r\n}\r\n</style>"],"mappings":";;EACWA,EAAE,EAAC,YAAY;EAACC,KAAK,EAAC;;;EACxBA,KAAK,EAAC;AAAW;;EAEfA,KAAK,EAAC;AAAU;;;EAGZA,KAAK,EAAC;AAAkB;;EACtBA,KAAK,EAAC;AAAe;;EAIrBA,KAAK,EAAC;AAAiB;;uBAXtCC,mBAAA,CAkBU,WAlBVC,UAkBU,GAjBRC,mBAAA,CAgBM,OAhBNC,UAgBM,G,0BAfJD,mBAAA,CAAiE;IAA7DH,KAAK,EAAC,eAAe;IAAC,UAAQ,EAAC;KAAU,iBAAe,qBAC5DG,mBAAA,CAaM,OAbNE,UAaM,I,kBAZJJ,mBAAA,CAWMK,SAAA,QAAAC,WAAA,CAXsBC,KAAA,CAAAC,WAAW,GAA1BC,GAAG,EAAEC,KAAK;yBAAvBV,mBAAA,CAWM;MAXoCW,GAAG,EAAED,KAAK;MAAEX,KAAK,EAAC,eAAe;MAAE,UAAQ,EAAEW,KAAK;kCAC1FR,mBAAA,CAAgC;MAA3BH,KAAK,EAAC;IAAc,4BACzBG,mBAAA,CAQM,OARNU,UAQM,GAPJV,mBAAA,CAA+C,OAA/CW,UAA+C,EAAAC,gBAAA,CAAjBL,GAAG,CAACM,IAAI,kBACt
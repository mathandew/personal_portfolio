{"ast":null,"code":"export default {\n  name: \"Contact\",\n  data() {\n    return {\n      formData: {\n        name: \"\",\n        email: \"\",\n        subject: \"\",\n        message: \"\"\n      },\n      isSubmitting: false,\n      submitSuccess: false,\n      submitError: false\n    };\n  },\n  methods: {\n    async submitForm() {\n      this.isSubmitting = true;\n      this.submitSuccess = false;\n      this.submitError = false;\n\n      // Simulate API call\n      setTimeout(() => {\n        this.isSubmitting = false;\n        this.submitSuccess = true;\n        this.formData = {\n          name: \"\",\n          email: \"\",\n          subject: \"\",\n          message: \"\"\n        };\n        setTimeout(() => {\n          this.submitSuccess = false;\n        }, 3000);\n      }, 1500);\n    }\n  }\n};","map":{"version":3,"names":["name","data","formData","email","subject","message","isSubmitting","submitSuccess","submitError","methods","submitForm","setTimeout"],"sources":["E:\\Portfolio-site\\my-portfolio\\src\\components\\Contact.vue"],"sourcesContent":["<template>\r\n  <section id=\"contact\" class=\"contact\">\r\n    <div class=\"container\">\r\n      <h2 class=\"section-title\" data-aos=\"fade-up\">Get In Touch</h2>\r\n      <div class=\"contact-content\">\r\n        <div class=\"contact-info\" data-aos=\"fade-right\">\r\n          <h3>Let's Work Together</h3>\r\n          <p>\r\n            I'm always interested in hearing about new projects and\r\n            opportunities.\r\n          </p>\r\n          <div class=\"info-items\">\r\n            <div class=\"info-item\">\r\n              <i class=\"fas fa-envelope\"></i>\r\n              <div>\r\n                <strong>Email</strong>\r\n                <p>john.doe@example.com</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"info-item\">\r\n              <i class=\"fas fa-phone\"></i>\r\n              <div>\r\n                <strong>Phone</strong>\r\n                <p>+1 (555) 123-4567</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"info-item\">\r\n              <i class=\"fas fa-map-marker-alt\"></i>\r\n              <div>\r\n                <strong>Location</strong>\r\n                <p>New York, NY 10001</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"social-links\">\r\n            <a href=\"#\" target=\"_blank\"><i class=\"fab fa-github\"></i></a>\r\n            <a href=\"#\" target=\"_blank\"><i class=\"fab fa-linkedin\"></i></a>\r\n            <a href=\"#\" target=\"_blank\"><i class=\"fab fa-twitter\"></i></a>\r\n            <a href=\"#\" target=\"_blank\"><i class=\"fab fa-instagram\"></i></a>\r\n          </div>\r\n        </div>\r\n\r\n        <form\r\n          class=\"contact-form\"\r\n          data-aos=\"fade-left\"\r\n          @submit.prevent=\"submitForm\"\r\n        >\r\n          <div class=\"form-group\">\r\n            <input\r\n              type=\"text\"\r\n              v-model=\"formData.name\"\r\n              placeholder=\"Your Name\"\r\n              required\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <input\r\n              type=\"email\"\r\n              v-model=\"formData.email\"\r\n              placeholder=\"Your Email\"\r\n              required\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <input\r\n              type=\"text\"\r\n              v-model=\"formData.subject\"\r\n              placeholder=\"Subject\"\r\n              required\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <textarea\r\n              v-model=\"formData.message\"\r\n              rows=\"5\"\r\n              placeholder=\"Your Message\"\r\n              required\r\n            ></textarea>\r\n          </div>\r\n          <button\r\n            type=\"submit\"\r\n            class=\"btn btn-primary\"\r\n            :disabled=\"isSubmitting\"\r\n          >\r\n            {{ isSubmitting ? \"Sending...\" : \"Send Message\" }}\r\n          </button>\r\n          <div v-if=\"submitSuccess\" class=\"success-message\">\r\n            Message sent successfully!\r\n          </div>\r\n          <div v-if=\"submitError\" class=\"error-message\">\r\n            Failed to send message. Please try again.\r\n          </div>\r\n        </form>\r\n      </div>\r\n    </div>\r\n  </section>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Contact\",\r\n  data() {\r\n    return {\r\n      formData: {\r\n        name: \"\",\r\n        email: \"\",\r\n        subject: \"\",\r\n        message: \"\",\r\n      },\r\n      isSubmitting: false,\r\n      submitSuccess: false,\r\n      submitError: false,\r\n    };\r\n  },\r\n  methods: {\r\n    async submitForm() {\r\n      this.isSubmitting = true;\r\n      this.submitSuccess = false;\r\n      this.submitError = false;\r\n\r\n      // Simulate API call\r\n      setTimeout(() => {\r\n        this.isSubmitting = false;\r\n        this.submitSuccess = true;\r\n        this.formData = {\r\n          name: \"\",\r\n          email: \"\",\r\n          subject: \"\",\r\n          message: \"\",\r\n        };\r\n        setTimeout(() => {\r\n          this.submitSuccess = false;\r\n        }, 3000);\r\n      }, 1500);\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.contact {\r\n  background: #f8f9fa;\r\n\r\n  .contact-content {\r\n    display: grid;\r\n    grid-template-columns: 1fr 1fr;\r\n    gap: 50px;\r\n\r\n    @media (max-width: 768px) {\r\n      grid-template-columns: 1fr;\r\n      gap: 30px;\r\n    }\r\n  }\r\n\r\n  .contact-info {\r\n    h3 {\r\n      font-size: 1.8rem;\r\n      margin-bottom: 20px;\r\n      color: #333;\r\n    }\r\n\r\n    p {\r\n      color: #666;\r\n      margin-bottom: 30px;\r\n      line-height: 1.6;\r\n    }\r\n\r\n    .info-items {\r\n      margin-bottom: 30px;\r\n\r\n      .info-item {\r\n        display: flex;\r\n        align-items: center;\r\n        gap: 20px;\r\n        margin-bottom: 20px;\r\n\r\n        i {\r\n          font-size: 1.5rem;\r\n          color: #4caf50;\r\n          width: 40px;\r\n        }\r\n\r\n        strong {\r\n          display: block;\r\n          color: #333;\r\n          margin-bottom: 5px;\r\n        }\r\n\r\n        p {\r\n          margin: 0;\r\n          color: #666;\r\n        }\r\n      }\r\n    }\r\n\r\n    .social-links {\r\n      display: flex;\r\n      gap: 20px;\r\n\r\n      a {\r\n        display: inline-flex;\r\n        align-items: center;\r\n        justify-content: center;\r\n        width: 45px;\r\n        height: 45px;\r\n        background: white;\r\n        border-radius: 50%;\r\n        color: #4caf50;\r\n        font-size: 1.2rem;\r\n        transition: all 0.3s ease;\r\n\r\n        &:hover {\r\n          background: #4caf50;\r\n          color: white;\r\n          transform: translateY(-3px);\r\n        }\r\n      }\r\n    }\r\n  }\r\n\r\n  .contact-form {\r\n    .form-group {\r\n      margin-bottom: 20px;\r\n\r\n      input,\r\n      textarea {\r\n        width: 100%;\r\n        padding: 12px 15px;\r\n        border: 1px solid #ddd;\r\n        border-radius: 8px;\r\n        font-family: inherit;\r\n        font-size: 1rem;\r\n        transition: border-color 0.3s ease;\r\n\r\n        &:focus {\r\n          outline: none;\r\n          border-color: #4caf50;\r\n        }\r\n      }\r\n    }\r\n\r\n    .success-message {\r\n      margin-top: 15px;\r\n      padding: 10px;\r\n      background: #d4edda;\r\n      color: #155724;\r\n      border-radius: 5px;\r\n      text-align: center;\r\n    }\r\n\r\n    .error-message {\r\n      margin-top: 15px;\r\n      padding: 10px;\r\n      background: #f8d7da;\r\n      color: #721c24;\r\n      border-radius: 5px;\r\n      text-align: center;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AAmGA,eAAe;EACbA,IAAI,EAAE,SAAS;EACfC,IAAIA
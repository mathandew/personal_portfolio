el\">Years Experience</div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"About\",\r\n  data() {\r\n    return {\r\n      aboutText:\r\n        \"I am a passionate Full Stack Developer with over 5 years of experience in building web applications. I love creating solutions that make a difference in people's lives. My expertise includes modern JavaScript frameworks, backend technologies, and database management.\",\r\n    };\r\n  },\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.about {\r\n  background: #f8f9fa;\r\n\r\n  .about-content {\r\n    display: grid;\r\n    grid-template-columns: 1fr 1fr;\r\n    gap: 50px;\r\n\r\n    @media (max-width: 768px) {\r\n      grid-template-columns: 1fr;\r\n      gap: 30px;\r\n    }\r\n\r\n    .about-text {\r\n      h3 {\r\n        font-size: 1.8rem;\r\n        margin-bottom: 20px;\r\n        color: #333;\r\n      }\r\n\r\n      p {\r\n        color: #666;\r\n        margin-bottom: 30px;\r\n        line-height: 1.8;\r\n      }\r\n\r\n      .personal-info {\r\n        .info-item {\r\n          margin-bottom: 15px;\r\n          padding: 10px;\r\n          background: white;\r\n          border-radius: 8px;\r\n\r\n          strong {\r\n            color: #333;\r\n            width: 100px;\r\n            display: inline-block;\r\n          }\r\n\r\n          span {\r\n            color: #666;\r\n          }\r\n        }\r\n      }\r\n    }\r\n\r\n    .about-stats {\r\n      display: grid;\r\n      grid-template-columns: repeat(3, 1fr);\r\n      gap: 20px;\r\n\r\n      .stat {\r\n        text-align: center;\r\n        padding: 30px;\r\n        background: white;\r\n        border-radius: 10px;\r\n        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\r\n\r\n        .stat-number {\r\n          font-size: 2.5rem;\r\n          font-weight: 700;\r\n          color: #4caf50;\r\n          margin-bottom: 10px;\r\n        }\r\n\r\n        .stat-label {\r\n          color: #666;\r\n          font-size: 0.9rem;\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA2CA,eAAe;EACbA,IAAI,EAAE,OAAO;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EACP;IACJ,CAAC;EACH;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
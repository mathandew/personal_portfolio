{"ast":null,"code":"export default {\n  name: \"Skills\",\n  data() {\n    return {\n      skills: [{\n        name: \"JavaScript/TypeScript\",\n        percentage: 90,\n        icon: \"fab fa-js\",\n        delay: 100\n      }, {\n        name: \"Vue.js / React\",\n        percentage: 85,\n        icon: \"fab fa-vuejs\",\n        delay: 200\n      }, {\n        name: \"Node.js / Python\",\n        percentage: 80,\n        icon: \"fab fa-node\",\n        delay: 300\n      }, {\n        name: \"HTML5 / CSS3\",\n        percentage: 95,\n        icon: \"fab fa-html5\",\n        delay: 400\n      }, {\n        name: \"MongoDB / PostgreSQL\",\n        percentage: 75,\n        icon: \"fas fa-database\",\n        delay: 500\n      }, {\n        name: \"Git & GitHub\",\n        percentage: 85,\n        icon: \"fab fa-git-alt\",\n        delay: 600\n      }]\n    };\n  }\n};","map":{"version":3,"names":["name","data","skills","percentage","icon","delay"],"sources":["E:\\Portfolio-site\\my-portfolio\\src\\components\\Skills.vue"],"sourcesContent":["<template>\r\n  <section id=\"skills\" class=\"skills\">\r\n    <div class=\"container\">\r\n      <h2 class=\"section-title\" data-aos=\"fade-up\">Technical Skills</h2>\r\n      <div class=\"skills-grid\">\r\n        <div\r\n          v-for=\"skill in skills\"\r\n          :key=\"skill.name\"\r\n          class=\"skill-card\"\r\n          data-aos=\"fade-up\"\r\n          :data-aos-delay=\"skill.delay\"\r\n        >\r\n          <div class=\"skill-icon\">\r\n            <i :class=\"skill.icon\"></i>\r\n          </div>\r\n          <h3>{{ skill.name }}</h3>\r\n          <div class=\"skill-bar\">\r\n            <div\r\n              class=\"skill-progress\"\r\n              :style=\"{ width: skill.percentage + '%' }\"\r\n            ></div>\r\n          </div>\r\n          <span class=\"skill-percentage\">{{ skill.percentage }}%</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Skills\",\r\n  data() {\r\n    return {\r\n      skills: [\r\n        {\r\n          name: \"JavaScript/TypeScript\",\r\n          percentage: 90,\r\n          icon: \"fab fa-js\",\r\n          delay: 100,\r\n        },\r\n        {\r\n          name: \"Vue.js / React\",\r\n          percentage: 85,\r\n          icon: \"fab fa-vuejs\",\r\n          delay: 200,\r\n        },\r\n        {\r\n          name: \"Node.js / Python\",\r\n          percentage: 80,\r\n          icon: \"fab fa-node\",\r\n          delay: 300,\r\n        },\r\n        {\r\n          name: \"HTML5 / CSS3\",\r\n          percentage: 95,\r\n          icon: \"fab fa-html5\",\r\n          delay: 400,\r\n        },\r\n        {\r\n          name: \"MongoDB / PostgreSQL\",\r\n          percentage: 75,\r\n          icon: \"fas fa-database\",\r\n          delay: 500,\r\n        },\r\n        {\r\n          name: \"Git & GitHub\",\r\n          percentage: 85,\r\n          icon: \"fab fa-git-alt\",\r\n          delay: 600,\r\n        },\r\n      ],\r\n    };\r\n  },\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.skills {\r\n  background: white;\r\n\r\n  .skills-grid {\r\n    display: grid;\r\n    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\r\n    gap: 30px;\r\n\r\n    .skill-card {\r\n      background: #f8f9fa;\r\n      padding: 25px;\r\n      border-radius: 10px;\r\n      text-align: center;\r\n      transition: transform 0.3s ease;\r\n\r\n      &:hover {\r\n        transform: translateY(-5px);\r\n      }\r\n\r\n      .skill-icon {\r\n        font-size: 3rem;\r\n        color: #4caf50;\r\n        margin-bottom: 15px;\r\n      }\r\n\r\n      h3 {\r\n        margin-bottom: 20px;\r\n        color: #333;\r\n      }\r\n\r\n      .skill-bar {\r\n        height: 8px;\r\n        background: #e0e0e0;\r\n        border-radius: 4px;\r\n        overflow: hidden;\r\n        margin-bottom: 10px;\r\n\r\n        .skill-progress {\r\n          height: 100%;\r\n          background: linear-gradient(90deg, #4caf50, #8bc34a);\r\n          border-radius: 4px;\r\n          transition: width 1s ease;\r\n        }\r\n      }\r\n\r\n      .skill-percentage {\r\n        font-size: 0.9rem;\r\n        color: #666;\r\n      }\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA8BA,eAAe;EACbA,IAAI,EAAE,QAAQ;EACdC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAE,CACN;QACEF,IAAI,EAAE,uBAAuB;QAC7BG,UAAU,EAAE,EAAE;QACdC,IAAI,EAAE,WAAW;QACjBC,KAAK,EAAE;MACT,CAAC,EACD;QACEL,IAAI,EAAE,gBAAgB;QACtBG,UAAU,EAAE,EAAE;QACdC,IAAI,EAAE,cAAc;QACpBC,KAAK,EAAE;MACT,CAAC,EACD;QACEL,IAAI,EAAE,kBAAkB;QACxBG,UAAU,EAAE,EAAE;QACdC,IAAI,EAAE,aAAa;QACnBC,KAAK,EAAE;MACT,CAAC,EACD;QACEL,IAAI,EAAE,cAAc;QACpBG,UAAU,EAAE,EAAE;QACdC,IAAI,EAAE,cAAc;QACpBC,KAAK,EAAE;MACT,CAAC,EACD;QACEL,IAAI,EAAE,sBAAsB;QAC5BG,UAAU,EAAE,EAAE;QACdC,IAAI,EAAE,iBAAiB;QACvBC,KAAK,EAAE;MACT,CAAC,EACD;QACEL,IAAI,EAAE,cAAc;QACpBG,UAAU,EAAE,EAAE;QACdC,IAAI,EAAE,gBAAgB;QACtBC,KAAK,EAAE;MACT,CAAC;IAEL,CAAC;EACH;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
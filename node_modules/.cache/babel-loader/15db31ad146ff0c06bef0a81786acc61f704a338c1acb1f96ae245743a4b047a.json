skill }}</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'Experience',\r\n  data() {\r\n    return {\r\n      experiences: [\r\n        {\r\n          date: '2022 - Present',\r\n          title: 'Senior Full Stack Developer',\r\n          company: 'Tech Solutions Inc.',\r\n          description: 'Leading development of enterprise web applications, mentoring junior developers, and implementing best practices.',\r\n          skills: ['Vue.js', 'Node.js', 'AWS', 'MongoDB']\r\n        },\r\n        {\r\n          date: '2019 - 2022',\r\n          title: 'Frontend Developer',\r\n          company: 'Creative Agency',\r\n          description: 'Developed responsive web applications, collaborated with designers, and optimized performance.',\r\n          skills: ['React', 'JavaScript', 'SASS', 'REST APIs']\r\n        },\r\n        {\r\n          date: '2017 - 2019',\r\n          title: 'Junior Web Developer',\r\n          company: 'Startup Hub',\r\n          description: 'Built and maintained client websites, fixed bugs, and implemented new features.',\r\n          skills: ['HTML/CSS', 'jQuery', 'PHP', 'MySQL']\r\n        }\r\n      ]\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.experience {\r\n  background: white;\r\n  \r\n  .timeline {\r\n    position: relative;\r\n    max-width: 800px;\r\n    margin: 0 auto;\r\n    \r\n    &::before {\r\n      content: '';\r\n      position: absolute;\r\n      left: 50%;\r\n      transform: translateX(-50%);\r\n      width: 2px;\r\n      height: 100%;\r\n      background: #4CAF50;\r\n      \r\n      @media (max-width: 768px) {\r\n        left: 30px;\r\n      }\r\n    }\r\n    \r\n    .timeline-item {\r\n      position: relative;\r\n      margin-bottom: 50px;\r\n      \r\n      .timeline-dot {\r\n        position: absolute;\r\n        left: 50%;\r\n        transform: translateX(-50%);\r\n        width: 15px;\r\n        height: 15px;\r\n        background: #4CAF50;\r\n        border-radius: 50%;\r\n        \r\n        @media (max-width: 768px) {\r\n          left: 30px;\r\n        }\r\n      }\r\n      \r\n      .timeline-content {\r\n        width: calc(50% - 50px);\r\n        padding: 20px;\r\n        background: #f8f9fa;\r\n        border-radius: 10px;\r\n        position: relative;\r\n        \r\n        @media (max-width: 768px) {\r\n          width: calc(100% - 70px);\r\n          margin-left: 70px;\r\n        }\r\n        \r\n        &::before {\r\n          content: '';\r\n          position: absolute;\r\n          top: 20px;\r\n          width: 20px;\r\n          height: 20px;\r\n          background: #f8f9fa;\r\n          transform: rotate(45deg);\r\n        }\r\n      }\r\n      \r\n      &:nth-child(odd) .timeline-content {\r\n        left: 0;\r\n        \r\n        &::before {\r\n          right: -10px;\r\n        }\r\n      }\r\n      \r\n      &:nth-child(even) .timeline-content {\r\n        left: calc(50% + 30px);\r\n        \r\n        &::before {\r\n          left: -10px;\r\n        }\r\n        \r\n        @media (max-width: 768px) {\r\n          left: 0;\r\n          \r\n          &::before {\r\n            left: -10px;\r\n          }\r\n        }\r\n      }\r\n    }\r\n  }\r\n  \r\n  .timeline-date {\r\n    color: #4CAF50;\r\n    font-weight: 600;\r\n    margin-bottom: 10px;\r\n  }\r\n  \r\n  h3 {\r\n    font-size: 1.3rem;\r\n    margin-bottom: 5px;\r\n    color: #333;\r\n  }\r\n  \r\n  h4 {\r\n    color: #666;\r\n    margin-bottom: 15px;\r\n    font-weight: 500;\r\n  }\r\n  \r\n  p {\r\n    color: #666;\r\n    line-height: 1.6;\r\n    margin-bottom: 15px;\r\n  }\r\n  \r\n  .timeline-skills {\r\n    display: flex;\r\n    flex-wrap: wrap;\r\n    gap: 8px;\r\n    \r\n    span {\r\n      background: white;\r\n      padding: 4px 12px;\r\n      border-radius: 15px;\r\n      font-size: 0.8rem;\r\n      color: #4CAF50;\r\n    }\r\n  }
{"ast":null,"code":"export default {\n  name: 'Skills',\n  data() {\n    return {\n      skills: [{\n        name: 'JavaScript/TypeScript',\n        percentage: 90,\n        icon: 'fab fa-js',\n        delay: 100\n      }, {\n        name: 'Vue.js / React',\n        percentage: 85,\n        icon: 'fab fa-vuejs',\n        delay: 200\n      }, {\n        name: 'Node.js / Python',\n        percentage: 80,\n        icon: 'fab fa-node',\n        delay: 300\n      }, {\n        name: 'HTML5 / CSS3',\n        percentage: 95,\n        icon: 'fab fa-html5',\n        delay: 400\n      }, {\n        name: 'MongoDB / PostgreSQL',\n        percentage: 75,\n        icon: 'fas fa-database',\n        delay: 500\n      }, {\n        name: 'Git & GitHub',\n        percentage: 85,\n        icon: 'fab fa-git-alt',\n        delay: 600\n      }]\n    };\n  }\n};","map":{"version":3,"names":["name","data","skills","percentage","icon","delay"],"sources":["E:\\Portfolio-site\\my-portfolio\\src\\components\\Skills.vue"],"sourcesContent":["<template>\r\n  <section id=\"skills\" class=\"skills\">\r\n    <div class=\"container\">\r\n      <h2 class=\"section-title\" data-aos=\"fade-up\">Technical Skills</h2>\r\n      <div class=\"skills-grid\">\r\n        <div v-for=\"skill in skills\" :key=\"skill.name\" class=\"skill-card\" data-aos=\"fade-up\" :data-aos-delay=\"skill.delay\">\r\n          <div class=\"skill-icon\">\r\n            <i :class=\"skill.icon\"></i>\r\n          </div>\r\n          <h3>{{ skill.name }}</h3>\r\n          <div class=\"skill-bar\">\r\n            <div class=\"skill-progress\" :style=\"{ width: skill.percentage + '%' }\"></div>\r\n          </div>\r\n          <span class=\"skill-percentage\">{{ skill.percentage }}%</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'Skills',\r\n  data() {\r\n    return {\r\n      skills: [\r\n        { name: 'JavaScript/TypeScript', percentage: 90, icon: 'fab fa-js', delay: 100 },\r\n        { name: 'Vue.js / React', percentage: 85, icon: 'fab fa-vuejs', delay: 200 },\r\n        { name: 'Node.js / Python', percentage: 80, icon: 'fab fa-node', delay: 300 },\r\n        { name: 'HTML5 / CSS3', percentage: 95, icon: 'fab fa-html5', delay: 400 },\r\n        { name: 'MongoDB / PostgreSQL', percentage: 75, icon: 'fas fa-database', delay: 500 },\r\n        { name: 'Git & GitHub', percentage: 85, icon: 'fab fa-git-alt', delay: 600 }\r\n      ]\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.skills {\r\n  background: white;\r\n  \r\n  .skills-grid {\r\n    display: grid;\r\n    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\r\n    gap: 30px;\r\n    \r\n    .skill-card {\r\n      background: #f8f9fa;\r\n      padding: 25px;\r\n      border-radius: 10px;\r\n      text-align: center;\r\n      transition: transform 0.3s ease;\r\n      \r\n      &:hover {\r\n        transform: translateY(-5px);\r\n      }\r\n      \r\n      .skill-icon {\r\n        font-size: 3rem;\r\n        color: #4CAF50;\r\n        margin-bottom: 15px;\r\n      }\r\n      \r\n      h3 {\r\n        margin-bottom: 20px;\r\n        color: #333;\r\n      }\r\n      \r\n      .skill-bar {\r\n        height: 8px;\r\n        background: #e0e0e0;\r\n        border-radius: 4px;\r\n        overflow: hidden;\r\n        margin-bottom: 10px;\r\n        \r\n        .skill-progress {\r\n          height: 100%;\r\n          background: linear-gradient(90deg, #4CAF50, #8BC34A);\r\n          border-radius: 4px;\r\n          transition: width 1s ease;\r\n        }\r\n      }\r\n      \r\n      .skill-percentage {\r\n        font-size: 0.9rem;\r\n        color: #666;\r\n      }\r\n    }\r\n  }\r\n}\r\n</style>"],"mappings":"AAqBA,eAAe;EACbA,IAAI,EAAE,QAAQ;EACdC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAE,CACN;QAAEF,IAAI,EAAE,uBAAuB;QAAEG,UAAU,EAAE,EAAE;QAAEC,IAAI,EAAE,WAAW;QAAEC,KAAK,EAAE;MAAI,CAAC,EAChF;QAAEL,IAAI,EAAE,gBAAgB;QAAEG,UAAU,EAA